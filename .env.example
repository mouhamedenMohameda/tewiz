# --- API ---
NODE_ENV=development
PORT=3000

# --- Database ---
# In dev, this connects through the SSH tunnel to your Contabo VPS:
#   ssh -L 5432:localhost:5432 -L 6379:localhost:6379 root@5.189.153.144
# Then locally it looks like Postgres is on 127.0.0.1:5432.
# Replace YOUR_DB_PASSWORD with the password generated by setup-contabo.sh.
DATABASE_URL=postgres://tewiz:YOUR_DB_PASSWORD@localhost:5432/tewiz

# --- Redis ---
# Also tunneled in dev (see DATABASE_URL).
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- OTP ---
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# In dev, OTPs are returned in API response and logged instead of sent by SMS.
SMS_PROVIDER=mock

# --- Twilio (later) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Storage ---
# In dev: local disk under apps/api/uploads.
# In prod: swap LocalDiskStorage for R2Storage.
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760            # 10 MB raw upload limit
IMAGE_MAX_WIDTH_PX=1600
IMAGE_JPEG_QUALITY=80

# Cloudflare R2 (later)
S3_ENDPOINT=
S3_BUCKET=tewiz-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# --- Business config ---
DEFAULT_COMMISSION_BPS=700           # 7.00% in basis points
COLIS_COMMISSION_BPS=1000            # 10.00% in basis points
MIN_BALANCE_TO_GO_ONLINE_KHOUMS=100  # 20 MRU (1 MRU = 5 khoums)
NEGATIVE_BALANCE_FLOOR_KHOUMS=-250   # -50 MRU floor before hard block
HOME_LOCK_DAYS=30
HOME_GPS_TOLERANCE_M=200
GOING_HOME_SESSION_MAX_HOURS=2
GOING_HOME_MAX_PER_DAY=2
GOING_HOME_ARRIVAL_RADIUS_M=500
