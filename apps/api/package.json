{
  "name": "@tewiz/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --pretty false; node -e \"const fs=require('fs');process.exit(fs.existsSync('dist/index.js')?0:1)\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate -m ../../db/migrations --envPath ../../.env --migration-file-language sql",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "clean:test-captain": "tsx scripts/clean-test-captain.ts",
    "clean:test-rider": "tsx scripts/clean-test-rider.ts"
  },
  "dependencies": {
    "@tewiz/shared-types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "h3-js": "^4.1.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.6.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
