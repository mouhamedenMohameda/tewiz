# Voice-to-Location API — example env. Copy to root .env or apps/voice-location-api/.env

# Server
VOICE_API_PORT=4100
NODE_ENV=development

# Database (Postgres) — used for API keys + usage logs.
# You can point this at the same DB as the main Tewiz API or a separate one.
VOICE_API_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/tewiz

# OpenAI Whisper (speech-to-text)
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Anthropic Claude (address extraction from transcript)
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google Maps Geocoding (text → lat/lng)
# Enable the "Geocoding API" in Google Cloud Console.
GOOGLE_MAPS_API_KEY=AIzaSy-REPLACE_ME

# Geocoding bias (helps Google return Mauritanian places first)
GEOCODE_REGION=mr
GEOCODE_LANGUAGE=fr
# Bounding box for Nouakchott — bias results inside this rectangle
# Format: south,west|north,east
GEOCODE_BOUNDS=17.85,-16.10|18.30,-15.70

# Upload limits
MAX_AUDIO_BYTES=10485760

# Default usage quota for newly minted API keys (0 = unlimited)
DEFAULT_MONTHLY_QUOTA=0
