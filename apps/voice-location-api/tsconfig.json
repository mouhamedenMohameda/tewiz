{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // rootDir is "src" (not ".") so the output is dist/index.js, not
    // dist/src/index.js. The scripts/*.ts files are run via tsx
    // directly (pnpm ingest-pois, pnpm create-key) and do not need
    // build emission.
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": "src",
    // Runtime-only API: no need to emit .d.ts files. Disabling avoids
    // the "inferred type cannot be named" errors that pnpm's non-flat
    // node_modules layout triggers when referencing types from
    // express-serve-static-core / pg / multer.
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"]
}
